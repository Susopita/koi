; ============================================================
; 21_float_arithmetic.carp
; Aritmética de punto flotante (f64)
; Salida esperada: imprime resultados en stdout
;
;   (+ 1.5 2.5) = 4.0
;   (- 5.0 3.0) = 2.0
;   (* 2.0 3.0) = 6.0
;   (/ 7.0 2.0) = 3.5
; ============================================================

(defn main []
  (do
    (print (+ 1.5 2.5))
    (print (- 5.0 3.0))
    (print (* 2.0 3.0))
    (print (/ 7.0 2.0))))
