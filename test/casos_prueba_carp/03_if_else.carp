; ============================================================
; 03_if_else.carp
; Condicional if/else anidado
; Salida esperada (exit code): 3
;
;   sign(5)  → positivo → 3
;   sign(-3) → negativo → 1
;   sign(0)  → cero     → 2
;   main llama sign(5) → 3
; ============================================================

(defn sign [n]
  (if (> n 0)
    3
    (if (< n 0)
      1
      2)))

(defn main []
  (sign 5))
